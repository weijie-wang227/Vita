datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  memberships Membership[]
  bookings   Booking[]
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  price            Int
  sessionsPerMonth Int
  perks            String[]
  classes          Class[]
}

model Class {
  id          String   @id @default(cuid())
  title       String
  instructor  String
  date        DateTime
  time        String
  duration    String
  location    String
  difficulty  String
  description String
  capacity    Int
  registered  Int
  price       Int
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  bookings    Booking[]
}

model Booking {
  id       String   @id @default(cuid())
  createdAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  classObj Class    @relation(fields: [classId], references: [id])
  classId  String
}
